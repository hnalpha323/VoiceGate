<Window x:Class="VoiceGate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceGate - only your voice gets through"
        Width="820" Height="860" MinWidth="720" MinHeight="700"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource FgBrush}"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="VoiceGate" FontSize="26" FontWeight="Bold"/>
                    <TextBlock Text="Personal voice isolator - background noise and other voices never reach your apps."
                               Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button x:Name="BtnStartStop" Grid.Column="1" Style="{StaticResource AccentButton}"
                        Content="&#9654;  Start" FontSize="16" MinWidth="150" VerticalAlignment="Center"
                        Click="StartStop_Click"/>
            </Grid>

            <!-- VB-Cable banner -->
            <Border x:Name="CableBanner" Grid.Row="1" Background="#FF3A2A12" BorderBrush="{StaticResource WarnBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12" Visibility="Collapsed">
                <TextBlock TextWrapping="Wrap">
                    <Run FontWeight="Bold" Foreground="#FFFFB020">VB-Audio Virtual Cable is not installed.</Run>
                    <Run>VoiceGate needs it to create the virtual microphone that Discord and other apps will use. Download the free driver from</Run>
                    <Hyperlink NavigateUri="https://vb-audio.com/Cable/" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#FF9C7DFF">vb-audio.com/Cable</Hyperlink><Run>, run the installer as administrator, reboot, then click Refresh.</Run>
                </TextBlock>
            </Border>

            <!-- Devices -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="MICROPHONE (real input)" Style="{StaticResource SectionTitle}"/>
                        <ComboBox x:Name="CmbMic" Foreground="Black" SelectionChanged="Device_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SEND CLEAN AUDIO TO (virtual cable)" Style="{StaticResource SectionTitle}"/>
                        <ComboBox x:Name="CmbOutput" Foreground="Black" SelectionChanged="Device_SelectionChanged"/>
                    </StackPanel>
                    <Button Grid.Column="4" x:Name="BtnRefreshDevices" Style="{StaticResource GhostButton}"
                            Content="Refresh" VerticalAlignment="Bottom" Click="RefreshDevices_Click"/>
                </Grid>
            </Border>

            <!-- Profile + models -->
            <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="YOUR VOICEPRINT" Style="{StaticResource SectionTitle}"/>
                        <TextBlock x:Name="TxtProfileStatus" Text="No voice profile enrolled yet." TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Row="0" Grid.Column="1" x:Name="BtnEnroll" Style="{StaticResource AccentButton}"
                            Content="Enroll my voice..." VerticalAlignment="Center" Click="Enroll_Click"/>
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,0,0">
                        <TextBlock Text="AI MODELS" Style="{StaticResource SectionTitle}"/>
                        <TextBlock x:Name="TxtModelsStatus" Text="Checking..." TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Row="1" Grid.Column="1" x:Name="BtnDownloadModels" Style="{StaticResource GhostButton}"
                            Content="Download models..." VerticalAlignment="Bottom" Margin="0,12,0,0"
                            Click="DownloadModels_Click"/>
                </Grid>
            </Border>

            <!-- Gate settings -->
            <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="VOICE GATE" Style="{StaticResource SectionTitle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode" VerticalAlignment="Center" Margin="0,4"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="CmbMode" Foreground="Black" Margin="0,4"
                                  SelectionChanged="Mode_SelectionChanged">
                            <ComboBoxItem Content="VAD only - pass any speech (no speaker check)"/>
                            <ComboBoxItem Content="Balanced - open fast, cut off other voices (recommended)"/>
                            <ComboBoxItem Content="Strict - open only after your voice is confirmed"/>
                        </ComboBox>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Voice match threshold" VerticalAlignment="Center" Margin="0,4"/>
                        <Slider Grid.Row="1" Grid.Column="1" x:Name="SldThreshold" Minimum="0.15" Maximum="0.65"
                                TickFrequency="0.01" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,4"
                                ValueChanged="Threshold_ValueChanged"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" x:Name="TxtThreshold" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Noise reduction (dB)" VerticalAlignment="Center" Margin="0,4"/>
                        <Slider Grid.Row="2" Grid.Column="1" x:Name="SldReduction" Minimum="6" Maximum="40"
                                TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,4"
                                ValueChanged="Reduction_ValueChanged"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" x:Name="TxtReduction" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Gate release (ms)" VerticalAlignment="Center" Margin="0,4"/>
                        <Slider Grid.Row="3" Grid.Column="1" x:Name="SldRelease" Minimum="50" Maximum="500"
                                TickFrequency="10" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,4"
                                ValueChanged="Release_ValueChanged"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" x:Name="TxtRelease" VerticalAlignment="Center" HorizontalAlignment="Right"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Lookahead (ms)" VerticalAlignment="Center" Margin="0,4"
                                   ToolTip="Delays output so the gate can open before your first syllable. Applied on next Start."/>
                        <Slider Grid.Row="4" Grid.Column="1" x:Name="SldLookahead" Minimum="0" Maximum="300"
                                TickFrequency="10" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,4"
                                ValueChanged="Lookahead_ValueChanged"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" x:Name="TxtLookahead" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <CheckBox x:Name="ChkDenoise" Content="Noise reduction" Foreground="{StaticResource FgBrush}"
                                  Checked="Denoise_Changed" Unchecked="Denoise_Changed" Margin="0,0,18,0"/>
                        <CheckBox x:Name="ChkExclusive" Content="Take exclusive control of the mic" Foreground="{StaticResource FgBrush}"
                                  ToolTip="Other apps cannot open the raw microphone while VoiceGate runs. Applied on next Start."
                                  Margin="0,0,18,0"/>
                        <CheckBox x:Name="ChkMonitor" Content="Monitor (hear the result)" Foreground="{StaticResource FgBrush}"
                                  ToolTip="Plays the processed audio on your default speakers. Applied on next Start."/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Live meters -->
            <Border Grid.Row="5" Style="{StaticResource Card}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="LIVE" Style="{StaticResource SectionTitle}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Mic in" VerticalAlignment="Center" Margin="0,5"/>
                    <ProgressBar Grid.Row="1" Grid.Column="1" x:Name="MeterIn" Style="{StaticResource Meter}"
                                 Minimum="0" Maximum="1" Margin="0,5"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Clean out" VerticalAlignment="Center" Margin="0,5"/>
                    <ProgressBar Grid.Row="2" Grid.Column="1" x:Name="MeterOut" Style="{StaticResource Meter}"
                                 Minimum="0" Maximum="1" Margin="0,5" Foreground="{StaticResource AccentBrush}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Voice match" VerticalAlignment="Center" Margin="0,5"/>
                    <ProgressBar Grid.Row="3" Grid.Column="1" x:Name="MeterSim" Style="{StaticResource Meter}"
                                 Minimum="0" Maximum="1" Margin="0,5" Foreground="{StaticResource WarnBrush}"/>

                    <StackPanel Grid.Row="1" Grid.RowSpan="3" Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <Ellipse x:Name="GateLight" Width="12" Height="12" Fill="#FF444450" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtGate" Text="Gate closed"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <Ellipse x:Name="VadLight" Width="12" Height="12" Fill="#FF444450" Margin="0,0,8,0"/>
                            <TextBlock Text="Speech detected"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtSim" Text="match: -" Foreground="{StaticResource MutedBrush}" Margin="20,3,0,0"/>
                        <TextBlock x:Name="TxtBuffer" Text="" Foreground="{StaticResource MutedBrush}" Margin="20,3,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="6" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="CONNECT YOUR APPS" Style="{StaticResource SectionTitle}"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}">
                        In Discord: Settings &#8594; Voice &amp; Video &#8594; Input Device &#8594; "CABLE Output (VB-Audio Virtual Cable)".
                        Also turn OFF Discord's own Noise Suppression and Automatic Gain Control for best results.
                        Any other app works the same way - pick CABLE Output as its microphone.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button x:Name="BtnSetDefaultMic" Style="{StaticResource GhostButton}"
                                Content="Make virtual mic the Windows default" Click="SetDefaultMic_Click"/>
                        <TextBlock x:Name="TxtStatusMsg" Text="" VerticalAlignment="Center" Margin="14,0,0,0"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
