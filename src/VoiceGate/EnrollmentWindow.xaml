<Window x:Class="VoiceGate.EnrollmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enroll your voice" Width="640" Height="560"
        Background="{StaticResource BgBrush}" Foreground="{StaticResource FgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Teach VoiceGate what you sound like" FontSize="20" FontWeight="Bold"/>
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,12">
                Read the text below aloud in your normal speaking voice, at your normal distance from the
                microphone, in the room where you usually talk. Recording stops automatically after 30 seconds;
                you can stop earlier once you have read everything (at least ~15 seconds of speech).
            </TextBlock>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <TextBlock TextWrapping="Wrap" FontSize="15" LineHeight="24">
                "The quick brown fox jumps over the lazy dog while bright violet clouds drift above the
                quiet harbor. Yesterday I measured the temperature twice, and both readings showed
                twenty-seven degrees. Please call Stella and ask her to bring six spoons of fresh snow
                peas, five thick slabs of blue cheese, and maybe a snack for her brother Bob. Counting
                slowly now: one, two, three, four, five, six, seven, eight, nine, ten."
            </TextBlock>
        </Border>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Level" VerticalAlignment="Center" Margin="0,4"/>
            <ProgressBar Grid.Row="0" Grid.Column="1" x:Name="MeterLevel" Style="{StaticResource Meter}"
                         Minimum="0" Maximum="1" Margin="0,4"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Recorded" VerticalAlignment="Center" Margin="0,4"/>
            <ProgressBar Grid.Row="1" Grid.Column="1" x:Name="PrgTime" Style="{StaticResource Meter}"
                         Minimum="0" Maximum="30" Margin="0,4" Foreground="{StaticResource AccentBrush}"/>
            <TextBlock Grid.Row="1" Grid.Column="2" x:Name="TxtTime" Text="0 s" VerticalAlignment="Center"
                       HorizontalAlignment="Right"/>
        </Grid>

        <TextBlock Grid.Row="3" x:Name="TxtStatus" TextWrapping="Wrap" Margin="0,12,0,0"
                   Foreground="{StaticResource MutedBrush}"
                   Text="Press Record when you are ready."/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnRecord" Style="{StaticResource AccentButton}" Content="&#9210;  Record"
                    MinWidth="140" Click="Record_Click"/>
            <Button x:Name="BtnAccept" Style="{StaticResource AccentButton}" Content="Save voiceprint"
                    MinWidth="140" Margin="10,0,0,0" Click="Accept_Click" IsEnabled="False"/>
            <Button Style="{StaticResource GhostButton}" Content="Cancel" Margin="10,0,0,0" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
