<Window x:Class="VoiceGate.DownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Download AI models" Width="560" Height="380"
        Background="{StaticResource BgBrush}" Foreground="{StaticResource FgBrush}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="One-time model download" FontSize="20" FontWeight="Bold"/>

        <StackPanel Grid.Row="1" Margin="0,10,0,0">
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}">
                VoiceGate uses open-source AI models for speech detection and speaker verification.
                They are fetched once from the official sherpa-onnx project releases on GitHub
                (github.com/k2-fsa/sherpa-onnx) and stored locally in %APPDATA%\VoiceGate\models.
            </TextBlock>
            <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                <TextBlock x:Name="TxtFileList" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <ProgressBar Grid.Row="2" x:Name="PrgDownload" Style="{StaticResource Meter}" Height="14"
                     Minimum="0" Maximum="1" Margin="0,14,0,0" Foreground="{StaticResource AccentBrush}"/>
        <TextBlock Grid.Row="3" x:Name="TxtDlStatus" Margin="0,8,0,0" Foreground="{StaticResource MutedBrush}"
                   Text="Waiting for confirmation."/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnDownload" Style="{StaticResource AccentButton}" Content="Download"
                    MinWidth="130" Click="Download_Click"/>
            <Button x:Name="BtnClose" Style="{StaticResource GhostButton}" Content="Close"
                    Margin="10,0,0,0" MinWidth="100" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
